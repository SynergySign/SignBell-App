# ======================================
# SignBell 백엔드 환경변수 설정
# ======================================
# 이 파일을 복사하여 .env 파일을 생성하고,
# 각자의 API 키와 설정값으로 변경해주세요.

# 서버 설정
SERVER_PORT=9000

# 배포용 데이터베이스 설정
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# JWT 설정 (보안을 위해 반드시 본인만의 비밀키로 변경하세요)
# 최소 256비트(32자) 이상의 랜덤 문자열을 사용하세요
# 액세스 토큰 수명 15분, 리프레시 토큰 수명 7일
JWT_SECRET=kq2B8xv4zJ9L1t6Q3w8Y2u5R7o0M3n6B9c2E5h8J1k4=
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# COOKIE 설정
COOKIE_ACCESS_TOKEN_MAX_AGE=900
COOKIE_REFRESH_TOKEN_MAX_AGE=604800

# OAuth2 설정 (카카오 개발자센터에서 발급)
# https://developers.kakao.com/
KAKAO_CLIENT_ID=your_kakao_client_id_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here